{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "lib": ["es2015", "dom"],
    "jsx": "react-native",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["jest", "react-native"],
    "strict": false
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
